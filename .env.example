NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional. Recommended for the API route so signature uploads and inserts
# happen server-side without exposing elevated credentials to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Defaults to signature-images.
SUPABASE_SIGNATURES_BUCKET=signature-images

# Required for /admin.
ADMIN_PASSWORD=12345
